{
    "name": "ssh521/laravel-popup",
    "description": "Popup, banner, and notice bar management package for laravel-admin.",
    "version": "1.0.0",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "ssh521"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^13.0",
        "ssh521/laravel-admin": "^1.0",
        "ssh521/laravel-file": "^1.0"
    },
    "require-dev": {
        "orchestra/testbench": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Ssh521\\LaravelPopup\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ssh521\\LaravelPopup\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit --configuration phpunit.xml.dist"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ssh521\\LaravelPopup\\LaravelPopupServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
